# Base de données — SQLite en dev, PostgreSQL en prod
DATABASE_URL=sqlite:///./scoolize.db

# Sécurité JWT — À REMPLACER par un secret aléatoire >= 32 octets en production
JWT_SECRET=change-me-to-a-long-random-secret-of-at-least-32-bytes
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Origines autorisées (front), séparées par des virgules
CORS_ORIGINS=http://localhost:3000
